generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// === עסק ===
model Business {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  logoUrl        String?  @map("logo_url")
  coverImageUrl  String?  @map("cover_image_url")
  brandColor     String?  @default("#D4AF37") @map("brand_color")
  phone          String?
  address        String?
  about          String?
  terms          String?
  socialLinks    String?  @map("social_links") // JSON string
  facebookPixel  String?  @map("facebook_pixel")
  passwordHash   String?  @map("password_hash")
  // ── WhatsApp / Messaging ──
  whatsappNumber        String? @map("whatsapp_number")          // E.164 format, e.g. 972501234567
  messagingProvider     String? @default("green_api") @map("messaging_provider") // green_api | meta_cloud | none
  greenApiInstanceId    String? @map("green_api_instance_id")
  greenApiToken         String? @map("green_api_token")
  // ── Feature flags ──
  features       String?  // JSON: { reminders: true, reminder_24h: true, reminder_2h: false, agent: false }
  // ── Reminder message templates (null = use built-in default) ──
  reminder24hTemplate   String?  @map("reminder_24h_template")
  reminder2hTemplate    String?  @map("reminder_2h_template")
  // ── Re-engagement automation ──
  reengageEnabled       Boolean  @default(false) @map("reengage_enabled")
  reengageWeeks         Int      @default(6)     @map("reengage_weeks")
  reengageTemplate      String?  @map("reengage_template")
  // ── Theme / branding ──
  secondaryColor  String?  @default("#ffffff") @map("secondary_color")
  bgColor         String?  @default("#faf9f7") @map("bg_color")
  textColor       String?  @default("#171717") @map("text_color")
  // ── Booking calendar ──
  bookingHorizonDays    Int      @default(30) @map("booking_horizon_days")
  minBookingLeadMinutes Int      @default(0)  @map("min_booking_lead_minutes")
  settings       String?  // JSON string
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  staff          Staff[]
  services       Service[]
  customers      Customer[]
  appointments   Appointment[]
  waitlist       Waitlist[]
  announcements  Announcement[]
  products       Product[]
  messageLogs    MessageLog[]
  recurringAppointments RecurringAppointment[]
  automations           Automation[]
  stories        Story[]

  @@map("businesses")
}

// === לוג הודעות ===
model MessageLog {
  id            String   @id @default(uuid())
  businessId    String   @map("business_id")
  appointmentId String?  @map("appointment_id")
  customerPhone String   @map("customer_phone")
  kind          String   // confirmation | reminder_24h | otp | broadcast | manual | agent_reply
  status        String   @default("queued") // queued | sent | delivered | read | failed
  providerId    String?  @map("provider_id")   // ID from WhatsApp provider
  body          String
  error         String?
  createdAt     DateTime @default(now()) @map("created_at")
  sentAt        DateTime? @map("sent_at")
  deliveredAt   DateTime? @map("delivered_at")
  readAt        DateTime? @map("read_at")

  business      Business @relation(fields: [businessId], references: [id])

  @@index([businessId, createdAt])
  @@index([appointmentId])
  @@map("message_logs")
}

// === צוות ===
model Staff {
  id            String   @id @default(uuid())
  businessId    String   @map("business_id")
  phone         String?
  name          String
  nickname      String?
  avatarUrl     String?  @map("avatar_url")
  role          String   @default("barber") // owner, manager, barber
  isAvailable   Boolean  @default(true) @map("is_available")
  inQuickPool   Boolean  @default(false) @map("in_quick_pool")
  poolPriority  Int      @default(0) @map("pool_priority")
  passwordHash  String?  @map("password_hash")
  settings      String?  // JSON string
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  business      Business @relation(fields: [businessId], references: [id])
  schedules     StaffSchedule[]
  overrides     StaffScheduleOverride[]
  staffServices StaffService[]
  appointments  Appointment[]
  waitlist      Waitlist[]
  portfolio     PortfolioItem[]
  recurringAppointments RecurringAppointment[]

  @@map("staff")
}

// === שעות עבודה קבועות ===
model StaffSchedule {
  id          String  @id @default(uuid())
  staffId     String  @map("staff_id")
  dayOfWeek   Int     @map("day_of_week") // 0=Sunday
  isWorking   Boolean @default(true) @map("is_working")
  slots       String  // JSON: [{start: "09:00", end: "20:00"}]
  breaks      String? // JSON: [{start: "13:00", end: "13:30"}]

  staff       Staff   @relation(fields: [staffId], references: [id])

  @@unique([staffId, dayOfWeek])
  @@map("staff_schedules")
}

// === חריגים ===
model StaffScheduleOverride {
  id          String  @id @default(uuid())
  staffId     String  @map("staff_id")
  date        DateTime
  isWorking   Boolean @default(false) @map("is_working")
  slots       String? // JSON
  breaks      String? // JSON
  reason      String?

  staff       Staff   @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@map("staff_schedule_overrides")
}

// === שירותים ===
model Service {
  id              String   @id @default(uuid())
  businessId      String   @map("business_id")
  name            String
  description     String?
  price           Float
  durationMinutes Int      @map("duration_minutes")
  color           String?  @default("#D4AF37")
  icon            String?
  note            String?
  isVisible       Boolean  @default(true) @map("is_visible")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  business        Business @relation(fields: [businessId], references: [id])
  staffServices   StaffService[]
  appointments    Appointment[]
  waitlist        Waitlist[]
  recurringAppointments RecurringAppointment[]

  @@map("services")
}

// === שירות לפי ספר ===
model StaffService {
  staffId        String  @map("staff_id")
  serviceId      String  @map("service_id")
  customPrice    Float?  @map("custom_price")
  customDuration Int?    @map("custom_duration")

  staff          Staff   @relation(fields: [staffId], references: [id])
  service        Service @relation(fields: [serviceId], references: [id])

  @@id([staffId, serviceId])
  @@map("staff_services")
}

// === לקוחות ===
model Customer {
  id                String    @id @default(uuid())
  businessId        String    @map("business_id")
  phone             String
  name              String
  referralSource    String?   @map("referral_source")
  referredById      String?   @map("referred_by_id")
  isBlocked         Boolean   @default(false) @map("is_blocked")
  pushToken         String?   @map("push_token")
  notificationPrefs String?   @map("notification_prefs") // JSON
  createdAt         DateTime  @default(now()) @map("created_at")
  lastVisitAt       DateTime? @map("last_visit_at")

  business          Business   @relation(fields: [businessId], references: [id])
  referredBy        Customer?  @relation("CustomerReferral", fields: [referredById], references: [id])
  referrals         Customer[] @relation("CustomerReferral")
  appointments      Appointment[]
  waitlist          Waitlist[]
  recurringAppointments RecurringAppointment[]

  @@unique([businessId, phone])
  @@map("customers")
}

// === תורים ===
model Appointment {
  id             String   @id @default(uuid())
  businessId     String   @map("business_id")
  customerId     String   @map("customer_id")
  staffId        String   @map("staff_id")
  serviceId      String   @map("service_id")
  date           DateTime
  startTime      String   @map("start_time") // "14:30"
  endTime        String   @map("end_time")   // "15:00"
  status         String   @default("confirmed") // pending, confirmed, cancelled_by_customer, cancelled_by_staff, completed, no_show
  price          Float
  note           String?
  staffNote      String?  @map("staff_note")
  referralSource String?  @map("referral_source")
  referredById   String?  @map("referred_by_id")
  cancelledAt    DateTime? @map("cancelled_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  recurringId    String?  @map("recurring_id")

  business       Business @relation(fields: [businessId], references: [id])
  customer       Customer @relation(fields: [customerId], references: [id])
  staff          Staff    @relation(fields: [staffId], references: [id])
  service        Service  @relation(fields: [serviceId], references: [id])
  recurring      RecurringAppointment? @relation(fields: [recurringId], references: [id])

  @@index([recurringId])
  @@map("appointments")
}

// === תור קבוע (recurring) ===
// Rule row that spawns recurring Appointment records.
// Owner picks day-of-week + time + frequency (every N weeks) + start date
// and we generate appointments forward up to `horizonWeeks` weeks.
model RecurringAppointment {
  id             String   @id @default(uuid())
  businessId     String   @map("business_id")
  customerId     String   @map("customer_id")
  staffId        String   @map("staff_id")
  serviceId      String   @map("service_id")
  dayOfWeek      Int      @map("day_of_week") // 0=Sunday
  startTime      String   @map("start_time")  // "14:30"
  frequencyWeeks Int      @default(1) @map("frequency_weeks") // 1=weekly, 2=biweekly, 4=monthly
  startDate      DateTime @map("start_date")
  endDate        DateTime? @map("end_date")
  price          Float?
  note           String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  business       Business @relation(fields: [businessId], references: [id])
  customer       Customer @relation(fields: [customerId], references: [id])
  staff          Staff    @relation(fields: [staffId], references: [id])
  service        Service  @relation(fields: [serviceId], references: [id])
  appointments   Appointment[]

  @@map("recurring_appointments")
}

// === רשימת המתנה ===
model Waitlist {
  id           String   @id @default(uuid())
  businessId   String   @map("business_id")
  customerId   String   @map("customer_id")
  staffId      String?  @map("staff_id")
  serviceId    String   @map("service_id")
  date         DateTime
  isFlexible   Boolean  @default(false) @map("is_flexible")
  status              String   @default("waiting") // waiting, notified, booked, expired
  preferredTimeOfDay  String?  @map("preferred_time_of_day") // morning | afternoon | any
  createdAt    DateTime @default(now()) @map("created_at")

  business     Business @relation(fields: [businessId], references: [id])
  customer     Customer @relation(fields: [customerId], references: [id])
  staff        Staff?   @relation(fields: [staffId], references: [id])
  service      Service  @relation(fields: [serviceId], references: [id])

  @@map("waitlist")
}

// === עדכונים / פינבורד ===
model Announcement {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  title       String
  content     String?
  isPinned    Boolean  @default(false) @map("is_pinned")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  business    Business @relation(fields: [businessId], references: [id])

  @@map("announcements")
}

// === מוצרים ===
model Product {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  name        String
  description String?
  price       Float
  imageUrl    String?  @map("image_url")
  isVisible   Boolean  @default(true) @map("is_visible")
  sortOrder   Int      @default(0) @map("sort_order")

  business    Business @relation(fields: [businessId], references: [id])

  @@map("products")
}

// === אוטומציות ===
// type: reengage | post_first_visit | post_every_visit
// settings JSON per type:
//   reengage:         { inactiveWeeks: 6, excludeWithFutureAppt: true, segment: "all"|"new_only"|"regular_only" }
//   post_first_visit: { delayMinutes: 30, ctaType: "google_review"|"instagram"|"custom", ctaUrl: string }
//   post_every_visit: { delayMinutes: 60, segment: "regular_only", minVisits: 2 }
model Automation {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  type        String   // reengage | post_first_visit | post_every_visit
  active      Boolean  @default(false)
  name        String
  settings    String   // JSON with type-specific config
  template    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business    Business @relation(fields: [businessId], references: [id])

  @@map("automations")
}

// === סטוריז ===
model Story {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  mediaUrl    String   @map("media_url")   // image URL
  caption     String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  expiresAt   DateTime? @map("expires_at")  // null = never expires
  createdAt   DateTime @default(now()) @map("created_at")

  business    Business @relation(fields: [businessId], references: [id])

  @@map("stories")
}

// === גלריית עבודות / סטוריז ===
model PortfolioItem {
  id          String   @id @default(uuid())
  staffId     String   @map("staff_id")
  imageUrl    String   @map("image_url")
  caption     String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  staff       Staff    @relation(fields: [staffId], references: [id])

  @@map("portfolio_items")
}
