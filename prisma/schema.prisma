generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// === עסק ===
model Business {
  id             String   @id @default(uuid())
  name           String
  slug           String   @unique
  logoUrl        String?  @map("logo_url")
  coverImageUrl  String?  @map("cover_image_url")
  brandColor     String?  @default("#D4AF37") @map("brand_color")
  phone          String?
  address        String?
  about          String?
  terms          String?
  socialLinks    String?  @map("social_links") // JSON string
  facebookPixel  String?  @map("facebook_pixel")
  passwordHash   String?  @map("password_hash")
  // ── WhatsApp / Messaging ──
  whatsappNumber        String? @map("whatsapp_number")          // E.164 format, e.g. 972501234567
  messagingProvider     String? @default("green_api") @map("messaging_provider") // green_api | meta_cloud | none
  greenApiInstanceId    String? @map("green_api_instance_id")
  greenApiToken         String? @map("green_api_token")
  // ── Feature flags ──
  features       String?  // JSON: { reminders: true, reminder_24h: true, reminder_2h: false, agent: false }
  // ── Message templates (null = use built-in default) ──
  reminder24hTemplate     String?  @map("reminder_24h_template")
  reminder2hTemplate      String?  @map("reminder_2h_template")
  confirmationTemplate    String?  @map("confirmation_template")
  swapProposalTemplate      String?  @map("swap_proposal_template")
  moveProposalTemplate      String?  @map("move_proposal_template")
  swapConfirmationTemplate  String?  @map("swap_confirmation_template")
  appointmentMovedTemplate  String?  @map("appointment_moved_template")
  delayNotificationTemplate String?  @map("delay_notification_template")
  // ── Re-engagement automation ──
  reengageEnabled       Boolean  @default(false) @map("reengage_enabled")
  reengageWeeks         Int      @default(6)     @map("reengage_weeks")
  reengageTemplate      String?  @map("reengage_template")
  // ── Theme / branding ──
  secondaryColor  String?  @default("#ffffff") @map("secondary_color")
  bgColor         String?  @default("#faf9f7") @map("bg_color")
  textColor       String?  @default("#171717") @map("text_color")
  // ── Booking calendar ──
  bookingHorizonDays    Int      @default(30) @map("booking_horizon_days")
  minBookingLeadMinutes Int      @default(0)  @map("min_booking_lead_minutes")
  // ── Chats / customer messaging ──
  chatsEnabled          Boolean  @default(false) @map("chats_enabled")
  settings       String?  // JSON string
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  staff          Staff[]
  services       Service[]
  customers      Customer[]
  appointments   Appointment[]
  waitlist       Waitlist[]
  announcements  Announcement[]
  products       Product[]
  messageLogs    MessageLog[]
  recurringAppointments RecurringAppointment[]
  automations           Automation[]
  stories        Story[]
  conversations  Conversation[]
  agentConfig    AgentConfig?
  swapProposals  SwapProposal[]

  @@map("businesses")
}

// === לוג הודעות ===
model MessageLog {
  id            String   @id @default(uuid())
  businessId    String   @map("business_id")
  appointmentId String?  @map("appointment_id")
  customerPhone String   @map("customer_phone")
  kind          String   // confirmation | reminder_24h | otp | broadcast | manual | agent_reply
  status        String   @default("queued") // queued | sent | delivered | read | failed
  providerId    String?  @map("provider_id")   // ID from WhatsApp provider
  body          String
  error         String?
  createdAt     DateTime @default(now()) @map("created_at")
  sentAt        DateTime? @map("sent_at")
  deliveredAt   DateTime? @map("delivered_at")
  readAt        DateTime? @map("read_at")

  business      Business @relation(fields: [businessId], references: [id])

  @@index([businessId, createdAt])
  @@index([appointmentId])
  @@map("message_logs")
}

// === צוות ===
model Staff {
  id            String   @id @default(uuid())
  businessId    String   @map("business_id")
  phone         String?
  name          String
  nickname      String?
  avatarUrl     String?  @map("avatar_url")
  role          String   @default("barber") // owner, manager, barber
  isAvailable   Boolean  @default(true) @map("is_available")
  inQuickPool   Boolean  @default(false) @map("in_quick_pool")
  poolPriority  Int      @default(0) @map("pool_priority")
  passwordHash  String?  @map("password_hash")
  settings      String?  // JSON string
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  business      Business @relation(fields: [businessId], references: [id])
  schedules     StaffSchedule[]
  overrides     StaffScheduleOverride[]
  staffServices StaffService[]
  appointments  Appointment[]
  waitlist      Waitlist[]
  portfolio     PortfolioItem[]
  stories       Story[]
  recurringAppointments RecurringAppointment[]

  @@map("staff")
}

// === שעות עבודה קבועות ===
model StaffSchedule {
  id          String  @id @default(uuid())
  staffId     String  @map("staff_id")
  dayOfWeek   Int     @map("day_of_week") // 0=Sunday
  isWorking   Boolean @default(true) @map("is_working")
  slots       String  // JSON: [{start: "09:00", end: "20:00"}]
  breaks      String? // JSON: [{start: "13:00", end: "13:30"}]

  staff       Staff   @relation(fields: [staffId], references: [id])

  @@unique([staffId, dayOfWeek])
  @@map("staff_schedules")
}

// === חריגים ===
model StaffScheduleOverride {
  id          String  @id @default(uuid())
  staffId     String  @map("staff_id")
  date        DateTime
  isWorking   Boolean @default(false) @map("is_working")
  slots       String? // JSON
  breaks      String? // JSON
  reason      String?

  staff       Staff   @relation(fields: [staffId], references: [id])

  @@unique([staffId, date])
  @@map("staff_schedule_overrides")
}

// === שירותים ===
model Service {
  id              String   @id @default(uuid())
  businessId      String   @map("business_id")
  name            String
  description     String?
  price           Float
  durationMinutes Int      @map("duration_minutes")
  color           String?  @default("#D4AF37")
  icon            String?
  note            String?
  isVisible       Boolean  @default(true) @map("is_visible")
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  business        Business @relation(fields: [businessId], references: [id])
  staffServices   StaffService[]
  appointments    Appointment[]
  waitlist        Waitlist[]
  recurringAppointments RecurringAppointment[]

  @@map("services")
}

// === שירות לפי ספר ===
model StaffService {
  staffId        String  @map("staff_id")
  serviceId      String  @map("service_id")
  customPrice    Float?  @map("custom_price")
  customDuration Int?    @map("custom_duration")

  staff          Staff   @relation(fields: [staffId], references: [id])
  service        Service @relation(fields: [serviceId], references: [id])

  @@id([staffId, serviceId])
  @@map("staff_services")
}

// === לקוחות ===
model Customer {
  id                String    @id @default(uuid())
  businessId        String    @map("business_id")
  phone             String
  name              String
  referralSource    String?   @map("referral_source")
  referredById      String?   @map("referred_by_id")
  isBlocked         Boolean   @default(false) @map("is_blocked")
  pushToken         String?   @map("push_token")
  notificationPrefs String?   @map("notification_prefs") // JSON
  createdAt         DateTime  @default(now()) @map("created_at")
  lastVisitAt       DateTime? @map("last_visit_at")

  business          Business   @relation(fields: [businessId], references: [id])
  referredBy        Customer?  @relation("CustomerReferral", fields: [referredById], references: [id])
  referrals         Customer[] @relation("CustomerReferral")
  appointments      Appointment[]
  waitlist          Waitlist[]
  recurringAppointments RecurringAppointment[]
  conversations     Conversation[]

  @@unique([businessId, phone])
  @@map("customers")
}

// === תורים ===
model Appointment {
  id             String   @id @default(uuid())
  businessId     String   @map("business_id")
  customerId     String   @map("customer_id")
  staffId        String   @map("staff_id")
  serviceId      String   @map("service_id")
  date           DateTime
  startTime      String   @map("start_time") // "14:30"
  endTime        String   @map("end_time")   // "15:00"
  status         String   @default("confirmed") // pending, confirmed, cancelled_by_customer, cancelled_by_staff, completed, no_show
  price          Float
  note           String?
  staffNote      String?  @map("staff_note")
  referralSource String?  @map("referral_source")
  referredById   String?  @map("referred_by_id")
  cancelledAt    DateTime? @map("cancelled_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  recurringId    String?  @map("recurring_id")

  business       Business @relation(fields: [businessId], references: [id])
  customer       Customer @relation(fields: [customerId], references: [id])
  staff          Staff    @relation(fields: [staffId], references: [id])
  service        Service  @relation(fields: [serviceId], references: [id])
  recurring      RecurringAppointment? @relation(fields: [recurringId], references: [id])

  swapsAsPrimary   SwapProposal[] @relation("SwapPrimary")
  swapsAsCandidate SwapProposal[] @relation("SwapCandidate")

  @@index([recurringId])
  @@map("appointments")
}

// === הצעת החלפת/העברת תורים ===
// Two flavors discriminated by `kind`:
//   "swap" — the customer is asked to TRADE slots with another customer (the
//            classic case). `candidateAppointmentId` is the other customer's
//            appointment. Approving the proposal swaps both appointments'
//            slot+staff atomically.
//   "move" — the customer is asked to MOVE to a free slot (no other customer
//            involved). `candidateAppointmentId` is null and the target slot
//            lives on `targetStaffId` + `targetDate` + `targetStartTime`.
//            Approving the proposal just relocates the primary appointment.
//
// One row per (primary, candidate) — when admin offers 3 candidates we create
// 3 rows. The first to reach `accepted_by_customer` is the one the admin is
// invited to approve; siblings get auto-cancelled on approval.
//
// Lifecycle:
//   pending_response     → message sent, awaiting customer reply
//   accepted_by_customer → customer said yes (manually marked OR detected by bot)
//   rejected_by_customer → customer said no
//   approved             → admin clicked "approve" and the change was executed
//   cancelled            → admin or system cancelled
//   expired              → 24h passed without response
model SwapProposal {
  id                     String    @id @default(uuid())
  businessId             String    @map("business_id")
  primaryAppointmentId   String    @map("primary_appointment_id")

  // Discriminator (default "swap" for backward-compat with existing rows)
  kind                   String    @default("swap") // "swap" | "move"

  // For kind=swap: the appointment to trade with
  candidateAppointmentId String?   @map("candidate_appointment_id")
  // For kind=move: the empty slot to relocate to
  targetStaffId          String?   @map("target_staff_id")
  targetDate             DateTime? @map("target_date")
  targetStartTime        String?   @map("target_start_time")

  status                 String    @default("pending_response")
  rawResponse            String?   @map("raw_response") // free-text customer reply, if captured
  createdAt              DateTime  @default(now()) @map("created_at")
  respondedAt            DateTime? @map("responded_at")
  approvedAt             DateTime? @map("approved_at")
  expiresAt              DateTime  @map("expires_at") // createdAt + 24h

  business  Business     @relation(fields: [businessId], references: [id])
  primary   Appointment  @relation("SwapPrimary",   fields: [primaryAppointmentId],   references: [id])
  candidate Appointment? @relation("SwapCandidate", fields: [candidateAppointmentId], references: [id])

  @@index([businessId, status])
  @@index([primaryAppointmentId, status])
  @@index([candidateAppointmentId, status])
  @@map("swap_proposals")
}

// === תור קבוע (recurring) ===
// Rule row that spawns recurring Appointment records.
// Owner picks day-of-week + time + frequency (every N weeks) + start date
// and we generate appointments forward up to `horizonWeeks` weeks.
model RecurringAppointment {
  id             String   @id @default(uuid())
  businessId     String   @map("business_id")
  customerId     String   @map("customer_id")
  staffId        String   @map("staff_id")
  serviceId      String   @map("service_id")
  dayOfWeek      Int      @map("day_of_week") // 0=Sunday
  startTime      String   @map("start_time")  // "14:30"
  frequencyWeeks Int      @default(1) @map("frequency_weeks") // 1=weekly, 2=biweekly, 4=monthly
  startDate      DateTime @map("start_date")
  endDate        DateTime? @map("end_date")
  price          Float?
  note           String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at")

  business       Business @relation(fields: [businessId], references: [id])
  customer       Customer @relation(fields: [customerId], references: [id])
  staff          Staff    @relation(fields: [staffId], references: [id])
  service        Service  @relation(fields: [serviceId], references: [id])
  appointments   Appointment[]

  @@map("recurring_appointments")
}

// === רשימת המתנה ===
model Waitlist {
  id           String   @id @default(uuid())
  businessId   String   @map("business_id")
  customerId   String   @map("customer_id")
  staffId      String?  @map("staff_id")
  serviceId    String   @map("service_id")
  date         DateTime
  isFlexible   Boolean  @default(false) @map("is_flexible")
  status              String   @default("waiting") // waiting, notified, booked, expired
  preferredTimeOfDay  String?  @map("preferred_time_of_day") // morning | afternoon | any
  createdAt    DateTime @default(now()) @map("created_at")

  business     Business @relation(fields: [businessId], references: [id])
  customer     Customer @relation(fields: [customerId], references: [id])
  staff        Staff?   @relation(fields: [staffId], references: [id])
  service      Service  @relation(fields: [serviceId], references: [id])

  @@map("waitlist")
}

// === עדכונים / פינבורד ===
model Announcement {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  title       String
  content     String?
  isPinned    Boolean  @default(false) @map("is_pinned")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  business    Business @relation(fields: [businessId], references: [id])

  @@map("announcements")
}

// === מוצרים ===
model Product {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  name        String
  description String?
  price       Float
  imageUrl    String?  @map("image_url")
  isVisible   Boolean  @default(true) @map("is_visible")
  sortOrder   Int      @default(0) @map("sort_order")

  business    Business @relation(fields: [businessId], references: [id])

  @@map("products")
}

// === אוטומציות ===
// type: reengage | post_first_visit | post_every_visit
// settings JSON per type:
//   reengage:         { inactiveWeeks: 6, excludeWithFutureAppt: true, segment: "all"|"new_only"|"regular_only" }
//   post_first_visit: { delayMinutes: 30, ctaType: "google_review"|"instagram"|"custom", ctaUrl: string }
//   post_every_visit: { delayMinutes: 60, segment: "regular_only", minVisits: 2 }
model Automation {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  type        String   // reengage | post_first_visit | post_every_visit
  active      Boolean  @default(false)
  name        String
  settings    String   // JSON with type-specific config
  template    String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business    Business @relation(fields: [businessId], references: [id])

  @@map("automations")
}

// === סטוריז ===
model Story {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  staffId     String?  @map("staff_id")    // optional — who this work belongs to
  mediaUrl    String   @map("media_url")   // image URL
  caption     String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  expiresAt   DateTime? @map("expires_at")  // null = never expires
  createdAt   DateTime @default(now()) @map("created_at")

  business    Business @relation(fields: [businessId], references: [id])
  staff       Staff?   @relation(fields: [staffId], references: [id])

  @@map("stories")
}

// === סוכן AI - שיחות ===
model Conversation {
  id          String   @id @default(uuid())
  businessId  String   @map("business_id")
  phone       String                          // customer WhatsApp phone
  customerId  String?  @map("customer_id")   // linked once identified
  agentType   String   @default("customer")  // customer | barber
  status      String   @default("active")    // active | resolved | escalated
  summary     String?                         // auto-summary after close
  // ── Manual escalation: when an admin sends a manual reply, agent is muted
  // for this conversation for 24h. Null = agent active. Logic is lazy:
  // checked on incoming message, cleared automatically when expired.
  escalatedAt   DateTime? @map("escalated_at")
  // ── Read marker: when any admin opens the conversation. Used to surface
  // unread customer messages with a badge in the nav. Shared across all admins.
  lastReadAt    DateTime? @map("last_read_at")
  // ── WhatsApp display name (from senderData.senderName). Captured by the
  // webhook on every incoming message — used as a fallback when the customer
  // is not in our DB so the chat list shows something meaningful.
  whatsappName  String?   @map("whatsapp_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  lastMessageAt DateTime? @map("last_message_at")

  business    Business  @relation(fields: [businessId], references: [id])
  customer    Customer? @relation(fields: [customerId], references: [id])
  messages    ConversationMessage[]

  @@index([businessId, phone])
  @@index([businessId, status])
  @@map("conversations")
}

model ConversationMessage {
  id             String   @id @default(uuid())
  conversationId String   @map("conversation_id")
  role           String   // user | assistant | tool
  source         String   @default("agent") // agent | admin — who sent it
  content        String   // message text (or JSON for tool calls)
  toolName       String?  @map("tool_name")
  toolCallId     String?  @map("tool_call_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

// === סוכן AI - הגדרות ===
model AgentConfig {
  id              String   @id @default(uuid())
  businessId      String   @unique @map("business_id")
  isEnabled       Boolean  @default(false) @map("is_enabled")
  agentName       String   @default("הסוכן") @map("agent_name")
  systemPrompt    String?  @map("system_prompt")   // override default prompt
  greetingMsg     String?  @map("greeting_msg")    // first message when agent starts
  escalatePhone   String?  @map("escalate_phone")  // barber phone to forward to
  maxIdleMinutes  Int      @default(30) @map("max_idle_minutes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  business  Business   @relation(fields: [businessId], references: [id])
  faqs      AgentFAQ[]

  @@map("agent_configs")
}

model AgentFAQ {
  id            String   @id @default(uuid())
  agentConfigId String   @map("agent_config_id")
  question      String
  answer        String
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at")

  agentConfig   AgentConfig @relation(fields: [agentConfigId], references: [id])

  @@map("agent_faqs")
}

// === גלריית עבודות / סטוריז ===
model PortfolioItem {
  id          String   @id @default(uuid())
  staffId     String   @map("staff_id")
  imageUrl    String   @map("image_url")
  caption     String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  staff       Staff    @relation(fields: [staffId], references: [id])

  @@map("portfolio_items")
}

// === קודי OTP לאימות בעת קביעת תור ===
model OtpCode {
  id          String    @id @default(uuid())
  businessId  String    @map("business_id")
  phone       String
  code        String
  expiresAt   DateTime  @map("expires_at")
  usedAt      DateTime? @map("used_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([businessId, phone, code])
  @@map("otp_codes")
}
